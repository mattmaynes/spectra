#!/bin/sh
# Spectra reflection reminder. Non-blocking: always exits 0.
# If a spec/plan/feedback doc changed but no overview living doc did, nudge the author
# to reflect (see docs/spectra/protocol.md, step 6).

staged=$(git diff --cached --name-only)

changed_work=$(printf '%s\n' "$staged" | grep -E '^docs/(specs|plans|feedback)/' | grep -v '/\.gitkeep$')
changed_overview=$(printf '%s\n' "$staged" | grep -E '^docs/overview/')

if [ -n "$changed_work" ] && [ -z "$changed_overview" ]; then
  y=$(printf '\033[33m'); r=$(printf '\033[0m')
  echo "${y}spectra:${r} specs/plans/feedback changed but docs/overview/ was not."
  echo "        Reflect before concluding - update project / features / architecture / learnings."
  echo "        (Reminder only; commit proceeds.)"
fi

exit 0
